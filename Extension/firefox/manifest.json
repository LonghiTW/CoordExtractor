{
    "manifest_version": 3,
    "name": "CoordExtractor",
    "version": "1.6",
    "description": "A coordinate extraction tool for map services.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "clipboardRead",
        "clipboardWrite"
    ],
    "host_permissions": [
        "*://*.google.com/*",
        "*://*.bing.com/*",
        "*://yandex.com/*",
        "*://maps.nlsc.gov.tw/*",
        "*://3dmaps.nlsc.gov.tw/*",
        "*://gis.ardswc.gov.tw/*",
        "*://ysnp.3dgis.tw/*",
        "*://3dmap.ymsnp.gov.tw/*",
        "*://urban.planning.ntpc.gov.tw/*",
        "*://urplanning.tycg.gov.tw/*",
        "*://tymap.tycg.gov.tw/*",
        "*://gismap.taichung.gov.tw/*",
        "*://gisdawh.kcg.gov.tw/*",
        "*://urbangis.kcg.gov.tw/*",
        "*://urbangis.hccg.gov.tw/*",
        "*://3dgis.hccg.gov.tw/*",
        "*://urbangis.chcg.gov.tw/*",
        "*://map.yunlin.gov.tw/*",
        "*://nsp.tcd.gov.tw/*",
        "*://map.taitung.gov.tw/*",
        "*://map.hl.gov.tw/*",
        "*://upgis.klcg.gov.tw/*",
        "*://urban.kinmen.gov.tw/kmgisweb/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "chip_extraction.png"
    },
    "icons": {
        "16": "chip_extraction.png",
        "48": "chip_extraction.png",
        "128": "chip_extraction.png"
    },
    "background": {
        "scripts": ["background.js"]
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.google.com/maps/*",
                "*://earth.google.com/web/*",
                "*://*.bing.com/*",
                "*://yandex.com/*",
                "*://maps.nlsc.gov.tw/*",
                "*://3dmaps.nlsc.gov.tw/*",
                "*://gis.ardswc.gov.tw/*",
                "*://ysnp.3dgis.tw/*",
                "*://3dmap.ymsnp.gov.tw/*",
                "*://urban.planning.ntpc.gov.tw/*",
                "*://urplanning.tycg.gov.tw/*",
                "*://tymap.tycg.gov.tw/*",
                "*://gismap.taichung.gov.tw/*",
                "*://gisdawh.kcg.gov.tw/*",
                "*://urbangis.kcg.gov.tw/*",
                "*://urbangis.hccg.gov.tw/*",
                "*://3dgis.hccg.gov.tw/*",
                "*://urbangis.chcg.gov.tw/*",
                "*://map.yunlin.gov.tw/*",
                "*://nsp.tcd.gov.tw/*",
                "*://map.taitung.gov.tw/*",
                "*://map.hl.gov.tw/*",
                "*://upgis.klcg.gov.tw/*",
                "*://urban.kinmen.gov.tw/kmgisweb/*"
            ],
            "css": ["content.css"],
            "js": [
                "utils.js",
                "config.js",
                "bte_projection.js",
                "content.js"
            ]
        }
    ],
    "commands": {
        "copy-coordinates": {
            "suggested_key": {
                "default": "Alt+C"
            },
            "description": "Copy coordinates"
        },
        "set-ground-elevation": {
            "suggested_key": {
                "default": "Alt+G"
            },
            "description": "Set captured elevation as Ground level"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "coordextractor@yourdomain.com",
            "strict_min_version": "109.0"
        }
    }
}
